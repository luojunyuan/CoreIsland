<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>CoreIsland</id>
    <version>1.0.2</version>
    <authors>CoreIsland</authors>
    <license type="expression">MIT</license>
    <readme>README.md</readme>
    <description>XAML Islands host library for unpackaged .NET 10 WinUI apps. Auto-injects build targets for MUX staging, PRI merging, XBF embedding, entry point patching, and InitializeComponent stubs.</description>
    <tags>xaml-islands winui winui2 mux xbf unpackaged net10 windows aot</tags>
    <repository type="git" url="https://github.com/luojunyuan/CoreIsland" />
    <dependencies>
      <group targetFramework="net10.0-windows10.0.26100" />
    </dependencies>
    <frameworkReferences>
      <group targetFramework="net10.0-windows10.0.26100">
        <frameworkReference name="Microsoft.Windows.SDK.NET.Ref.Xaml" />
      </group>
    </frameworkReferences>
  </metadata>
  <files>
    <!-- Runtime assembly -->
    <file src="bin\Release\net10.0-windows10.0.26100.0\win-x64\CoreIsland.dll" target="lib\net10.0-windows10.0.26100\CoreIsland.dll" />

    <!-- NuGet README (shown after install) -->
    <file src="README.md" target="\" />

    <!-- Auto-import wrappers (NuGet convention: build/{id}.props + build/{id}.targets) -->
    <file src="CoreIsland.props" target="build\CoreIsland.props" />
    <file src="CoreIsland.targets" target="build\CoreIsland.targets" />

    <!-- Feature files imported by the wrappers -->
    <file src="CoreIsland.XbfEmbed.props" target="build\CoreIsland.XbfEmbed.props" />
    <file src="CoreIsland.XbfEmbed.targets" target="build\CoreIsland.XbfEmbed.targets" />
    <file src="CoreIsland.Mux.props" target="build\CoreIsland.Mux.props" />
    <file src="CoreIsland.Mux.targets" target="build\CoreIsland.Mux.targets" />
    <file src="CoreIsland.AppMain.targets" target="build\CoreIsland.AppMain.targets" />

    <!-- PowerShell helpers (called by MSBuild Exec tasks, not init scripts) -->
    <file src="Utils\Prepare-Mux.ps1" target="build\Utils\Prepare-Mux.ps1" />
    <file src="Utils\Trim-MuxPri.ps1" target="build\Utils\Trim-MuxPri.ps1" />
    <file src="Utils\Patch-AppMain.ps1" target="build\Utils\Patch-AppMain.ps1" />
  </files>
</package>
